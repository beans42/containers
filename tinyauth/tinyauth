type       = process
command    = /usr/bin/podman run --replace --pull=newer \
	--name tinyauth \
	-p 127.0.0.1:19491:3000 \
	--add-host auth.ebra.dev:10.0.2.2 \
	--network=slirp4netns:allow_host_loopback=true,port_handler=slirp4netns \
	--env-file /home/ebrahim/containers/tinyauth/.env \
	--label-file=/home/ebrahim/containers/tinyauth/acl.txt \
	-v /home/ebrahim/containers/tinyauth/users.txt:/users.txt:ro \
	ghcr.io/steveiliop56/tinyauth:v4.1
run-as     = ebrahim
restart    = false
depends-on = network.target

log-type        = buffer
log-buffer-size = 65536
