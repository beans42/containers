# Public URL Rybbit should advertise for auth callbacks and API links.
BASE_URL=https://your.domain.com

# Generate a long random value, for example with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional feature flags and integrations.
DISABLE_SIGNUP=false
DISABLE_TELEMETRY=
MAPBOX_TOKEN=
CLUSTER_WORKERS=4
DEPLOYMENT=
LITE_DASHBOARD=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
