type       = process
command    = /usr/bin/podman run --replace --pull=newer \
	--name rybbit-postgres \
	-p 127.0.0.1:52721:5432 \
	--env-file /home/ebrahim/containers/rybbit/env/postgres.env \
	-v /home/ebrahim/containers/rybbit/data/postgres:/var/lib/postgresql/data \
	docker.io/postgres:17.4
run-as     = ebrahim
restart    = false
depends-on = network.target

log-type        = buffer
log-buffer-size = 65536
