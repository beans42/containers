type       = process
command    = /usr/bin/podman run --replace --pull=newer \
	--name rybbit-redis \
	-p 127.0.0.1:51253:6379 \
	--env-file /home/ebrahim/containers/rybbit/env/redis.env \
	-v /home/ebrahim/containers/rybbit/data/redis:/data \
	--entrypoint /bin/sh \
	docker.io/redis:7-alpine \
	-ec "exec redis-server --requirepass \"$$REDIS_PASSWORD\" --appendonly yes --appendfsync everysec --maxmemory-policy noeviction"
run-as     = ebrahim
restart    = false
depends-on = network.target

log-type        = buffer
log-buffer-size = 65536
