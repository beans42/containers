[Unit]
Description=Glance dashboard

[Container]
ContainerName=glance
Image=docker.io/glanceapp/glance
Pull=newer
PublishPort=127.0.0.1:50734:8080
Environment="MY_SECRET_TOKEN={{ glance_secret_token }}"
Volume=./config:/app/config:Z
Volume=./assets:/app/assets:Z
Volume=/usr/share/zoneinfo/America/Toronto:/etc/localtime:ro

[Service]
TimeoutStartSec=15min
# glance exits with status 2 when stopped by podman/systemd
SuccessExitStatus=2

[Install]
WantedBy=default.target
