---
server_url: https://headscale.{{ vps1.base_domain }}
listen_addr: 0.0.0.0:8080
trusted_proxies: [ {{ vps1.public_ipv4 }}/32, 169.254.1.2/32 ]

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: {{ vps1.headscale_ipv4_prefix }}
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

derp:
  server:
    enabled: true
    region_id: 999
    region_code: "headscale"
    region_name: "Headscale Embedded DERP"
    verify_clients: true
    stun_listen_addr: "0.0.0.0:3480"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
    ipv4: {{ vps1.public_ipv4 }}
    ipv6: {{ vps1.public_ipv6 }}
  urls: []
  paths: []
  auto_update_enabled: false

disable_check_updates: false

node:
  expiry: 0
  ephemeral:
    inactivity_timeout: 3m
  routes:
    ha:
      probe_interval: 10s
      probe_timeout: 5s

database:
  type: sqlite
  debug: false
  gorm:
    prepare_stmt: true
    parameterized_queries: true
    skip_err_record_not_found: true
    slow_threshold: 1000
  sqlite:
    path: /var/lib/headscale/db.sqlite
    write_ahead_log: true
    wal_autocheckpoint: 1000

policy:
  mode: database

dns:
  magic_dns: true
  base_domain: {{ vps1.headscale_domain }}
  override_local_dns: true
  nameservers:
    global: ['{{ vps1.tailnet_ipv4 }}']
    split: {}
  search_domains: [ '{{ vps1.base_domain }}' ]
  extra_records_path: "/etc/headscale/dns_records.json"

oidc:
  issuer: "https://auth.{{ vps1.base_domain }}"
  client_id: "{{ vps1.headscale_oidc_client_id }}"
  client_secret: "{{ vps1.priv_headscale_oidc_client_secret }}"
  pkce:
    enabled: true

logtail:
  enabled: false

taildrop:
  enabled: true

auto_update:
  enabled: true
