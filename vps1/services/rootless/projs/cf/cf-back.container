[Unit]
Description=CF backend

[Container]
ContainerName=cf-back
Image=docker.io/oven/bun:alpine
PodmanArgs=--interactive --tty
Pull=newer
PublishPort=127.0.0.1:20177:20177
Volume=/home/core/infra-template/vps1/projs/cf/back:/src:ro,Z
Volume=./entrypoint.sh:/usr/local/bin/entrypoint.sh:ro,Z
Volume=/home/core/infra-template/vps1/volumes/projs-cf-node:/app/node_modules:Z
WorkingDir=/app
Exec=/usr/local/bin/entrypoint.sh

[Service]
TimeoutStartSec=15min
ExecStartPre=/usr/bin/mkdir -p /home/core/infra-template/vps1/volumes/projs-cf-node

[Install]
WantedBy=default.target
