type       = process
command    = /usr/bin/podman run --replace --pull=newer \
	--name widgets \
	-p 127.0.0.1:26281:26281 \
	-v /home/ebrahim/projs/widgets:/app \
	-v /home/ebrahim/containers/projs/widgets/node_modules:/app/node_modules \
	-w /app \
	docker.io/oven/bun:alpine \
	sh -lc "bun install && bun run start"
run-as     = ebrahim
restart    = false
depends-on = network.target

log-type        = buffer
log-buffer-size = 65536
