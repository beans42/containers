	@cash host cash-api.ebra.dev
	@cash_book1_bypass {
		host cash-api.ebra.dev
		path /basicbalance/Book1.csv
		query auth={env.CSV_AUTH_TOKEN}
	}
	route @cash {
		handle @cash_book1_bypass {
			reverse_proxy 10.0.2.2:20077 {
				header_up -auth
			}
		}
		handle {
			forward_auth 10.0.2.2:19491 {
				uri /api/auth/caddy
				copy_headers Remote-User Remote-Name Remote-Email Remote-Groups
			}
			reverse_proxy 10.0.2.2:20077
		}
	}
	@cash-front host cash-front.ebra.dev
	reverse_proxy @cash-front 10.0.2.2:3390

	@rybbit host rybbit.ebra.dev
	route @rybbit {
		@rybbit-api path /api /api/*
		handle @rybbit-api {
			reverse_proxy 10.0.2.2:55401 {
				header_up X-Real-IP {remote_host}
			}
		}
		handle {
			reverse_proxy 10.0.2.2:52363
		}
	}

	@chat host chat.ebra.dev
